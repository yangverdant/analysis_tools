{
  "version": "1.0",
  "updated": "2026-05-20",
  "apis": {
    "sportmonks": {
      "name": "Sportmonks",
      "description": "足球数据API，覆盖全球联赛/杯赛，数据最全",
      "base_url": "https://api.sportmonks.com/v3/football",
      "auth_type": "query_param",
      "auth_key": "api_token",
      "api_token": "4iBqABzPSz3JX65i166agPqQiliD4f79vD7o2NrJX1OmMBt7wHJ2ttvxdQoq",
      "token_url": "https://my.sportmonks.com/api/tokens",
      "docs_url": "https://docs.sportmonks.com/football",
      "rate_limit": {
        "requests_per_minute": 30,
        "requests_per_month": 1000,
        "plan": "free",
        "free_plan_leagues": [
          "Superliga (DNK SL)",
          "Premiership (SCO P)",
          "Premiership Play-Offs (SCO P PO)",
          "Superliga Play-offs (DNK)"
        ],
        "note": "免费计划仅含4个联赛，五大联赛/世界杯需付费"
      },
      "request_interval_seconds": 2,
      "priority": 1,
      "status": "active",
      "capabilities": [
        "livescores",
        "fixtures",
        "standings",
        "teams",
        "players",
        "squad",
        "squad_statistics",
        "leagues",
        "seasons",
        "rounds",
        "events",
        "statistics",
        "trends",
        "lineups",
        "odds",
        "predictions",
        "xg",
        "head2head",
        "weather",
        "sidelined",
        "trophies",
        "career",
        "pressure",
        "news",
        "live_standings",
        "xgfixture",
        "referee"
      ],
      "data_fields": {
        "match": [
          "match_id (fixture.id)",
          "league_id",
          "season_id",
          "round_id / round_name",
          "starting_at (UTC时间)",
          "starting_at_timestamp",
          "state_id (比赛状态)",
          "venue_id",
          "name (如 'Getafe vs Real Madrid')",
          "leg (回合，如 1/1)",
          "length (比赛时长，默认90)",
          "has_odds / has_premium_odds",
          "referee (需include)",
          "attendance (需include)"
        ],
        "team_participant": [
          "team_id (participant.id)",
          "name",
          "short_code",
          "image_path (logo URL)",
          "country_id",
          "venue_id",
          "founded (成立年份)",
          "gender",
          "type (domestic/international)",
          "meta.location (home/away)",
          "meta.position (当前排名)",
          "meta.winner (是否获胜)"
        ],
        "scores": [
          "score.id",
          "score.fixture_id",
          "score.type (HT/FT/ET/PT 等)",
          "score.home_score",
          "score.away_score"
        ],
        "events": [
          "event.id",
          "event.fixture_id",
          "event.type (goal/substitution/card/var/period_start 等)",
          "event.player_id / player_name",
          "event.team_id",
          "event.minute",
          "event.extra_minute",
          "event.detail (如 own_goal, penalty, yellow, red 等)",
          "event.in / event.out (换人)"
        ],
        "periods": [
          "period.id",
          "period.fixture_id",
          "period.type (1st_half/2nd_half/extra_time/penalty 等)",
          "period.starting_at",
          "period.ending_at",
          "period.has_scores"
        ],
        "standings_detail": [
          "position",
          "played",
          "won",
          "draw",
          "lost",
          "goals_scored",
          "goals_against",
          "goal_difference",
          "points",
          "form (近5场结果，如 WWDWL)",
          "home/away 分榜 (需include details.type)"
        ],
        "team_detail": [
          "team_id",
          "name",
          "short_code",
          "image_path",
          "country_id / country.name",
          "venue_id / venue.name / venue.capacity / venue.city",
          "founded",
          "gender",
          "type",
          "coaches (需include)"
        ],
        "player_detail": [
          "player_id",
          "name / common_name / display_name",
          "image_path",
          "country_id / country.name",
          "position_id / position.name",
          "date_of_birth",
          "height / weight",
          "teams (历史球队，需include)"
        ],
        "squad": [
          "player_id",
          "player.name",
          "player.position",
          "player.country",
          "transfer_id",
          "active (是否当前在队)",
          "started_at / ended_at"
        ],
        "league": [
          "league_id",
          "name",
          "short_code",
          "image_path",
          "country_id / country.name / country.iso2",
          "type (league/cup)",
          "sub_type (domestic/international)",
          "category",
          "active",
          "currentSeason (需include)"
        ],
        "season": [
          "season_id",
          "name",
          "league_id",
          "is_current",
          "starting_at / ending_at"
        ],
        "round": [
          "round_id",
          "name (轮次号)",
          "league_id / season_id / stage_id",
          "finished",
          "is_current",
          "starting_at / ending_at"
        ],
        "venue": [
          "venue_id",
          "name",
          "capacity",
          "city",
          "country_id",
          "coordinates (latitude/longitude)",
          "image_path"
        ],
        "odds": [
          "odds_id",
          "market_id / market.name (如 Fulltime Result)",
          "bookmaker_id / bookmaker.name (如 bet365)",
          "label (如 1/X/2 或 Home/Draw/Away)",
          "value (赔率值，如 3.50)",
          "handicap",
          "total",
          "starting_at",
          "odds类型: pre-match (赛前赔率) 和 inplay (滚球赔率)",
          "50+庄家, 150+市场 (All-In计划)"
        ],
        "predictions": [
          "prediction_id",
          "fixture_id",
          "type_id / type.name / type.code",
          "Fulltime Result Probability: home/draw/away (如 67.18%/19.12%/13.69%)",
          "Correct Score Probability: scores对象 (如 1-0:10.18%, 2-1:9.49%...)",
          "Both Teams To Score Probability: yes/no (如 53.4%/46.6%)",
          "Over/Under 1.5/2.5/3.5/4.5 Probability: yes/no",
          "Home Over/Under 0.5/1.5/2.5/3.5 Probability: yes/no",
          "Away Over/Under 0.5/1.5/2.5/3.5 Probability: yes/no",
          "First Half Winner Probability: home/draw/away",
          "Half Time/Full Time Probability: home_home/home_draw/home_away/draw_home/draw_draw/draw_away/away_home/away_draw/away_away",
          "Double Chance Probability: draw_home/draw_away/home_away",
          "Team To Score First Probability: home/draw/away",
          "Corners Over/Under 4-11 Probability: yes/no/equal",
          "predictions为AI预测，仅All-In计划可用"
        ],
        "lineups": [
          "lineup_id",
          "fixture_id",
          "team_id",
          "player_id / player.name",
          "position_id / position.name",
          "formation (阵型)",
          "is_captain",
          "type (starting/substitute)",
          "sort_order"
        ],
        "statistics": [
          "stat_id",
          "fixture_id",
          "type (如 shots_total, shots_insidebox, attacks, dangerous_attacks, ball_safe, ball_recovery, fouls, corners, offsides, possession, passes_total, passes_accuracy, yellowcards, redcards, saves 等)",
          "home_value / away_value"
        ],
        "fixture_pressure": [
          "pressure.id",
          "pressure.fixture_id",
          "pressure.participant_id",
          "pressure.minute",
          "pressure.pressure (0~100+，高值=强烈压迫)",
          "pressure.participant.name",
          "仅All-In计划可用"
        ],
        "fixture_news": [
          "prematchNews.id / fixture_id / league_id / title / type",
          "prematchNews.lines[].text / type (introduction/home/away)",
          "postmatchNews.id / fixture_id / league_id / title / type",
          "postmatchNews.lines[].text / type (line)",
          "仅All-In计划可用"
        ],
        "fixture_xgfixture": [
          "xgfixture.fixture_id / type_id / participant_id / location",
          "xgfixture.data.value (xG值)",
          "type_id 5304: Expected Goals (xG)",
          "type_id 5305: Expected Goals on Target (xGoT)",
          "type_id 7939: Expected Points (xPTS)",
          "type_id 7940: Expected Goals Penalties (xGP)",
          "type_id 7941: Expected Goals Free Kicks (xGFK)",
          "type_id 7942: Expected Goals Corners (xGC)",
          "type_id 7943: Expected Goals Non Penalty Goals (npxG)",
          "type_id 7944: Expected Goals Set Play (xGSP)",
          "type_id 7945: Expected Goals Open Play (xGOP)",
          "type_id 9684: Expected Goals Difference (xGD)",
          "type_id 9685: Shooting Performance (SP)",
          "type_id 9686: Expected Goals Prevented (xGPrevented)",
          "type_id 9687: Expected Goals Against (xGA)"
        ],
        "fixture_sidelined_detail": [
          "sidelined.fixture_id / participant_id / player_id",
          "sideline.id / player_id / type_id / category",
          "sideline.category: injury 或 suspended",
          "sideline.start_date / end_date / games_missed / completed",
          "sideline.player: id/common_name/display_name/image_path/position_id/height/weight/date_of_birth",
          "sideline.type: id/name/code (如 muscle-injury, hamstring-injury, cruciate-ligament-tear, tendon-rupture, doping-ban, unknown-injury 等)"
        ],
        "referee": [
          "referee.id / common_name / firstname / lastname / display_name",
          "referee.country_id / country.name",
          "referee.image_path / date_of_birth",
          "statistics[].season_id / details[]",
          "details: type_id 188=Season Matches, 56=Fouls, 84=Yellowcards, 83=Redcards, 85=Yellowred Cards, 47=Penalties, 314=VAR Moments",
          "details.value: all/home/away (count/average/percentage)",
          "latest[]: 最近执法比赛(fixture_id + fixture含statistics/participants/scores)"
        ]
      },
