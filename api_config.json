      "endpoints": {
        "livescores_inplay": {
          "path": "/livescores/inplay",
          "method": "GET",
          "description": "进行中的比赛",
          "default_include": "participants;scores;periods;events;league.country;round"
        },
        "livescores_today": {
          "path": "/livescores",
          "method": "GET",
          "description": "今日所有比赛",
          "default_include": "participants;scores;periods;events;league.country;round"
        },
        "livescores_last": {
          "path": "/livescores/last",
          "method": "GET",
          "description": "最近完成的比赛",
          "default_include": "participants;scores;league.country;round"
        },
        "fixture_detail": {
          "path": "/fixtures/{id}",
          "method": "GET",
          "description": "单场比赛详情",
          "default_include": "participants;scores;periods;events;stats;league.country;round;venue;referee;lineups"
        },
        "fixtures_by_date": {
          "path": "/fixtures/date/{date}",
          "method": "GET",
          "description": "按日期查询赛程 (date: YYYY-MM-DD)",
          "default_include": "participants;scores;league.country;round"
        },
        "fixtures_between": {
          "path": "/fixtures/between/{from}/{to}",
          "method": "GET",
          "description": "日期范围查询赛程",
          "default_include": "participants;scores;league.country;round"
        },
        "league_fixtures": {
          "path": "/leagues/{league_id}/fixtures",
          "method": "GET",
          "description": "联赛赛程",
          "default_include": "participants;scores;league.country;round"
        },
        "season_fixtures": {
          "path": "/seasons/{season_id}/fixtures",
          "method": "GET",
          "description": "赛季赛程",
          "default_include": "participants;scores;league.country;round"
        },
        "team_fixtures": {
          "path": "/teams/{team_id}/fixtures",
          "method": "GET",
          "description": "球队赛程(扁平列表)",
          "default_include": "participants;scores;league.country;round"
        },
        "team_schedule": {
          "path": "/schedules/teams/{team_id}",
          "method": "GET",
          "description": "球队赛程表(按stage→round分组，含杯赛阶段区分)",
          "default_include": "fixtures.participants;scores;league.country;round",
          "filters": {
            "league_id": "过滤特定联赛",
            "location": "过滤主/客 (home/away)"
          },
          "note": "与team_fixtures不同：schedule按阶段和轮次分层组织，杯赛区分小组赛/淘汰赛，一次返回全部无分页"
        },
        "standings": {
          "path": "/standings/seasons/{season_id}",
          "method": "GET",
          "description": "赛季积分榜",
          "default_include": "participant;details;form"
        },
        "standings_live": {
          "path": "/standings/seasons/{season_id}/live",
          "method": "GET",
          "description": "实时积分榜",
          "default_include": "participant;details;form"
        },
        "leagues": {
          "path": "/leagues",
          "method": "GET",
          "description": "所有联赛",
          "default_include": "country;currentSeason"
        },
        "league_detail": {
          "path": "/leagues/{id}",
          "method": "GET",
          "description": "联赛详情",
          "default_include": "country;currentSeason;seasons"
        },
        "seasons": {
          "path": "/seasons",
          "method": "GET",
          "description": "所有赛季",
          "default_include": "league"
        },
        "teams": {
          "path": "/teams/{id}",
          "method": "GET",
          "description": "球队详情",
          "default_include": "country;venue"
        },
        "team_squad": {
          "path": "/teams/{id}/squad",
          "method": "GET",
          "description": "球队阵容(基础版)",
          "default_include": "player.country;player.position"
        },
        "team_squad_statistics": {
          "path": "/squads/teams/{team_id}",
          "method": "GET",
          "description": "球队阵容含球员赛季统计(进球/助攻/出场/评分/xG等)",
          "default_include": "team;player.nationality;player.statistics.details.type;player.position",
          "filters": {
            "playerstatisticSeasons": "赛季ID (如 25659)"
          },
          "note": "与team_squad不同：此端点返回每个球员的完整赛季统计数据(details)，可按赛季过滤"
        },
        "players": {
          "path": "/players/{id}",
          "method": "GET",
          "description": "球员详情(含职业生涯/奖杯/伤病/xG效率)",
          "default_include": "country;position;teams;trophies;career;stats;sidelined",
          "note": "stats包含xGlineup数据(每场比赛的xG/xA/评分等), sidelined包含伤病/停赛记录"
        },
        "player_xg_efficiency": {
          "path": "/players/{player_id}",
          "method": "GET",
          "description": "球员xG效率分析(每场比赛的xG/xGoT/SP及赛季汇总统计)",
          "default_include": "latest.xGlineup.type;statistics.details.type;statistics.season.league;statistics.position;latest.fixture.participants;latest.fixture.scores;nationality;latest.fixture.events;latest.fixture.league;teams.team",
          "filters": {
            "playerstatisticSeasons": "赛季ID (如 25659)",
            "playerstatisticdetailTypes": "统计类型ID (如 5304=xG)"
          },
          "note": "xGlineup包含每场比赛的xG(5304)/xGoT(5305)/Shooting Performance(9685), SP=Goals-xG"
        },
        "rounds": {
          "path": "/rounds/season/{season_id}",
          "method": "GET",
          "description": "赛季轮次",
          "default_include": "fixtures"
        },
        "fixture_trends": {
          "path": "/fixtures/{id}",
          "method": "GET",
          "description": "比赛详情含Trends(实时统计趋势，按分钟变化)",
          "default_include": "participants;league;venue;state;scores;events.type;events.period;events.player;trends.type;trends.participant",
          "note": "trends为比赛中的实时统计变化数据，包含dangerous_attacks/shots_total/passes/ball_possession/fouls/tackles等，按minute记录"
        },
        "head2head": {
          "path": "/fixtures/head-to-head/{team1_id}/{team2_id}",
          "method": "GET",
          "description": "两队历史交锋记录",
          "default_include": "participants;scores;league;round",
          "filters": {
            "league_id": "过滤特定联赛"
          }
        },
        "match_centre": {
          "path": "/fixtures/{id}",
          "method": "GET",
          "description": "比赛中心(含统计/伤病/天气/阵容/事件)",
          "default_include": "statistics;sidelined;weatherReport;lineups;events;participants;scores;periods"
        },
        "team_season_stats": {
          "path": "/teams/{team_id}",
          "method": "GET",
          "description": "球队赛季统计(射门/控球/传球/犯规/角球/xG等)",
          "default_include": "statistics.details.type",
          "filters": {
            "teamstatisticSeasons": "赛季ID",
            "teamstatisticdetailTypes": "统计类型ID"
          }
        },
        "team_upcoming_latest": {
          "path": "/teams/{team_id}",
          "method": "GET",
          "description": "球队即将/最近比赛",
          "default_include": "upcoming.participants;upcoming.league;latest.participants;latest.league;latest.scores"
        },
        "calendar": {
          "path": "/leagues/date/{date}",
          "method": "GET",
          "description": "按日期获取联赛赛程日历",
          "default_include": "today.scores;today.participants;today.stage;today.group;today.round",
          "note": "date格式: YYYY-MM-DD"
        },
        "pressure_index": {
          "path": "/fixtures/{id}",
          "method": "GET",
          "description": "比赛压力指数(每分钟压迫强度，按球队记录)",
          "default_include": "participants;league;venue;state;scores;events.type;events.player;pressure.participant",
          "note": "仅All-In计划可用，pressure值范围0~100+，高值=强烈压迫期"
        },
        "news_page": {
          "path": "/fixtures/{id}",
          "method": "GET",
          "description": "赛前/赛后AI新闻分析",
          "default_include": "prematchNews.lines;postmatchNews.lines;participants;league;venue;state;scores;events.type",
          "note": "仅All-In计划可用，prematchNews含introduction/home/away分析，postmatchNews含赛后总结段落"
        },
        "standings_live_league": {
          "path": "/standings/live/leagues/{league_id}",
          "method": "GET",
          "description": "按联赛获取实时积分榜(含当前轮次比赛)",
          "default_include": "stage;league;details.type;participant",
          "note": "与standings_live(按season)不同：此端点按league_id获取，返回当前轮次实时积分和比赛数据"
        },
        "team_recent_form": {
          "path": "/teams/{team_id}",
          "method": "GET",
          "description": "球队近期状态(含最近比赛统计+xG数据)",
          "default_include": "latest.statistics.type;latest.xgfixture.type;latest.participants;latest.scores.type",
          "note": "xgfixture包含每场比赛的xG(5304)/xGoT(5305)/xPTS(7939)/xGP(7940)/xGFK(7941)/xGC(7942)/npxG(7943)/xGSP(7944)/xGOP(7945)/xGD(9684)/SP(9685)/xGPrevented(9686)/xGA(9687)"
        },
        "fixture_sidelined": {
          "path": "/fixtures/{id}",
          "method": "GET",
          "description": "比赛伤病/停赛详情(含球员信息和伤病类型)",
          "default_include": "sidelined.sideline.player;sidelined.sideline.type;participants;league;venue;state",
          "note": "sideline含详细伤病信息：category(injury/suspended)、start_date、end_date、games_missed、type(如muscle-injury/hamstring-injury/cruciate-ligament-tear/doping-ban等)"
        },
        "referee_statistics": {
          "path": "/referees/{id}",
